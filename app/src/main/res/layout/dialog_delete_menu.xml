<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#66000000"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <!-- CARD DIALOG -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:background="@drawable/bg_menu_card"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingTop="8dp">

        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="28dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <!-- TITLE -->
            <TextView
                android:id="@+id/txtDeleteTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Apakah Kamu Yakin&#10;Menghapus Menu Tersebut?"
                android:textColor="@color/accent"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta" />

            <!-- IMAGE -->
            <ImageView
                android:id="@+id/imgDeleteMenu"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:layout_marginTop="26dp"
                android:src="@drawable/img_delete_kasir"
                android:scaleType="fitCenter" />

            <!-- BUTTON HAPUS -->
            <LinearLayout
                android:id="@+id/btnHapusMenu"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_input_yellow"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hapus"
                    android:textColor="@color/primary"
                    android:textSize="24sp"
                    android:fontFamily="@font/ibm_plex" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnCloseDeleteMenu"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-9dp"
            android:layout_marginEnd="-2dp"
            android:background="@drawable/bg_close_circle"
            android:elevation="20dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/ic_close" />

        </LinearLayout>

    </FrameLayout>

</RelativeLayout>