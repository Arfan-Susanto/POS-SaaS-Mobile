<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="170dp"
    android:layout_height="wrap_content"
    android:layout_marginBottom="20dp"
    android:background="@drawable/bg_card_menu"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- IMAGE -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgMenu"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_marginBottom="4dp"
        android:scaleType="centerCrop"
        android:src="@drawable/logo_bfc"
        app:shapeAppearanceOverlay="@style/RoundedImageMenu"
        app:strokeColor="@color/accent"
        app:strokeWidth="2dp" />

    <!-- TITLE -->
    <TextView
        android:id="@+id/txtNamaMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/plus_jakarta"
        android:text="Nasi + Ayam"
        android:textColor="@color/accent"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- CATEGORY -->
    <LinearLayout
        android:id="@+id/layoutKategori"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

    </LinearLayout>

    <!-- PRICE -->
    <TextView
        android:id="@+id/txtHarga"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/plus_jakarta"
        android:text="Rp 9.000"
        android:textColor="@color/accent"
        android:textSize="16sp" />

    <!-- ACTION -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/btnEdit"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_action_menu"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_edit" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnDelete"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_action_menu"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_delete" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>