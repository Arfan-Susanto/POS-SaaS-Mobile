<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_header_admin"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp"
            android:paddingTop="42dp">

            <!-- TOP ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- WELCOME -->
                <TextView
                    android:id="@+id/txtWelcome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/plus_jakarta"
                    android:text="Selamat datang"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- STORE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta"
                    android:text="BFC SIMPANG PASIR"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- ROLE + STATUS + DATE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <!-- LEFT -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- ROLE -->
                    <TextView
                        android:id="@+id/txtRole"
                        android:layout_width="80dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_role"
                        android:fontFamily="@font/plus_jakarta"
                        android:gravity="center"
                        android:text="ADMIN"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- STATUS -->
                    <TextView
                        android:id="@+id/txtStatus"
                        android:layout_width="100dp"
                        android:layout_height="34dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_role"
                        android:fontFamily="@font/plus_jakarta"
                        android:gravity="center"
                        android:text="TUTUP 🔴"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- RIGHT -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:orientation="vertical">

                    <!-- DATE -->
                    <TextView
                        android:id="@+id/txtDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta"
                        android:text="13 Mei 2026"
                        android:layout_marginTop="5dp"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- TIME CONTAINER -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_role"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:clipChildren="true"
                        android:clipToPadding="true">

                        <!-- HOUR -->
                        <TextView
                            android:id="@+id/txtHour"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta"
                            android:text="19"
                            android:textColor="@color/primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textColor="@color/primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <!-- MINUTE -->
                        <TextView
                            android:id="@+id/txtMinute"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta"
                            android:text="53"
                            android:textColor="@color/primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textColor="@color/primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <!-- SECOND -->
                        <TextView
                            android:id="@+id/txtSecond"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta"
                            android:text="41"
                            android:textColor="@color/primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- MENU CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="18dp"
            android:background="@drawable/bg_menu_card"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/plus_jakarta"
                android:text="Silahkan Pilih"
                android:textColor="@color/accent"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- FEATURE ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- EDIT KASIR -->
                <LinearLayout
                    android:id="@+id/btnEditKasir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="18dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_circle_accent"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_edit_kasir" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/ibm_plex"
                        android:text="Edit Kasir"
                        android:textColor="@color/accent"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- EDIT MENU -->
                <LinearLayout
                    android:id="@+id/btnEditMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="18dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_circle_accent"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_edit_menu" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/ibm_plex"
                        android:text="Edit Menu"
                        android:textColor="@color/accent"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- EDIT STOK -->
                <LinearLayout
                    android:id="@+id/btnEditStok"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="18dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_circle_accent"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_edit" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/ibm_plex"
                        android:text="Edit Stok"
                        android:textColor="@color/accent"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- DASHBOARD -->
                <LinearLayout
                    android:id="@+id/btnDashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_circle_accent"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_dashboard" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/ibm_plex"
                        android:text="Dashboard"
                        android:textColor="@color/accent"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- GAJI -->
            <LinearLayout
                android:id="@+id/btnSalary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="25dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_circle_accent"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_salary" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/ibm_plex"
                    android:text="Gaji Kasir"
                    android:textColor="@color/accent"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- PERINGATAN STOK -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta"
                android:text="Peringatan Stok"
                android:textColor="@color/primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerWarning"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="18dp"
                android:clipToPadding="false"
                android:paddingEnd="20dp"
                android:scrollbars="none" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>